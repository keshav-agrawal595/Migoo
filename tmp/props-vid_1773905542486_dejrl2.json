याद दिलाता है। हर मोड़ पर मानव इतिहास बदल सकता है। आज जो हम सामान्य मानते हैं, वह शायद कभी असामान्य होता। क्या हमेशा का स्वरूप वास्तव में हमेशा का होता है? कमेंट में बताएं, आपकी कल्पना किस तथ्य पर टिकी थी?","wordTimestamps":[{"end":0.38,"start":0,"word":"1773"},{"end":0.76,"start":0.38,"word":"में"},{"end":1.15,"start":0.76,"word":"एक"},{"end":1.53,"start":1.15,"word":"रहस्यमय"},{"end":1.91,"start":1.53,"word":"घटना"},{"end":2.29,"start":1.91,"word":"ने"},{"end":2.67,"start":2.29,"word":"बदल"},{"end":3.05,"start":2.67,"word":"दी"},{"end":3.44,"start":3.05,"word":"भारत"},{"end":3.82,"start":3.44,"word":"के"},{"end":4.2,"start":3.82,"word":"इतिहास"},{"end":4.58,"start":4.2,"word":"की"},{"end":4.96,"start":4.58,"word":"दिशा।"},{"end":5.34,"start":4.96,"word":"कल्पना"},{"end":5.73,"start":5.34,"word":"कीजिए"},{"end":6.11,"start":5.73,"word":"अगर"},{"end":6.49,"start":6.11,"word":"ब्रिटिश"},{"end":6.87,"start":6.49,"word":"ईस्ट"},{"end":7.25,"start":6.87,"word":"इंडिया"},{"end":7.64,"start":7.25,"word":"कंपनी"},{"end":8.02,"start":7.64,"word":"ने"},{"end":8.4,"start":8.02,"word":"अमृतसर"},{"end":8.78,"start":8.4,"word":"पर"},{"end":9.16,"start":8.78,"word":"कब्जा"},{"end":9.54,"start":9.16,"word":"कर"},{"end":9.93,"start":9.54,"word":"लिया"},{"end":10.31,"start":9.93,"word":"होता,"},{"end":10.69,"start":10.31,"word":"स्वर्ण"},{"end":11.07,"start":10.69,"word":"मंदिर"},{"end":11.45,"start":11.07,"word":"की"},{"end":11.84,"start":11.45,"word":"नींव"},{"end":12.22,"start":11.84,"word":"ही"},{"end":12.6,"start":12.22,"word":"ना"},{"end":12.98,"start":12.6,"word":"पड़ी"},{"end":13.36,"start":12.98,"word":"होती,"},{"end":13.74,"start":13.36,"word":"तो"},{"end":14.13,"start":13.74,"word":"आज"},{"end":14.51,"start":14.13,"word":"का"},{"end":14.89,"start":14.51,"word":"हरियाणा"},{"end":15.27,"start":14.89,"word":"और"},{"end":15.65,"start":15.27,"word":"पंजाब"},{"end":16.03,"start":15.65,"word":"अलग"},{"end":16.42,"start":16.03,"word":"नक्शे"},{"end":16.8,"start":16.42,"word":"पर"